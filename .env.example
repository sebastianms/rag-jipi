# --------------- LLM Provider API Keys ---------------
# Descomenta y rellena las claves de los proveedores que vayas a utilizar.
# LiteLLM las leerá automáticamente según el "model" que pidas en el endpoint.

# OpenAI (para modelos como gpt-4o, gpt-3.5-turbo)
# OPENAI_API_KEY="sk-tu-clave-aqui"

# Anthropic (para modelos como claude-3-opus, claude-3-sonnet)
# ANTHROPIC_API_KEY="sk-ant-tu-clave-aqui"

# Google Gemini (para modelos como gemini/gemini-pro)
# GEMINI_API_KEY="AIza-tu-clave-aqui"

# Mistral AI
# MISTRAL_API_KEY="tu-clave-mistral-aqui"

# Ollama local (por defecto asume http://localhost:11434). Solo des-comentar si usas otra IP/Puerto.
# OLLAMA_API_BASE="http://127.0.0.1:11434"

# --------------- Configuración General RAG ---------------

# Directorio donde Qdrant guardará los vectores de manera persistente
QDRANT_PATH="./qdrant_data"

# Modelo de HuggingFace utilizado por LangChain para calcular los embeddings locales
EMBEDDING_MODEL="all-MiniLM-L6-v2"
